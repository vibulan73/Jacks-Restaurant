# Jack's Norwood - Frontend Environment Variables (Example)
# Copy this file to .env and fill in your values

VITE_API_BASE_URL=http://localhost:8080/api
VITE_RESTAURANT_NAME=Jack's Norwood
VITE_RESTAURANT_PHONE=(08) 8234 5678
VITE_RESTAURANT_EMAIL=info@jacksnorwood.com.au
VITE_RESTAURANT_ADDRESS=123 The Parade, Norwood SA 5067

# Google Maps embed URL
# How to get it: Google Maps → search your location → Share → "Embed a map" → copy the src="..." value
VITE_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=...
